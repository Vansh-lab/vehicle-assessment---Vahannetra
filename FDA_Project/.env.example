# App
DEBUG=false
SECRET_KEY=generate-with-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://vahannetra:password@localhost:5432/vahannetra_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=vahannetra-images

# AI Models
YOLO_MODEL_PATH=ml/weights/vahannetra_yolov9.pt
EFFICIENTNET_MODEL_PATH=ml/weights/vahannetra_efficientnet_b4.pt
SAM2_MODEL_PATH=ml/weights/sam2_hiera_large.pt
MODEL_DEVICE=cpu

# Claude API (optional)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google Maps (optional)
GOOGLE_MAPS_API_KEY=your_key_optional

# VAHAN API (optional)
VAHAN_API_KEY=your_key_optional
VAHAN_BASE_URL=https://api.vahan.gov.in/v1
